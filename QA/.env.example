# ============ 阿里云百炼 API 配置 ============
BASE_URL=https://your-region.aliyuncs.com/compatible-mode/v1
API_KEY=your-api-key-here
MODEL_NAME=qwen-flash

# ============ Embedding 模型 ============
EMBEDDING_MODEL=text-embedding-v3
# 每批处理多少条文本，减少峰值内存
EMBEDDING_BATCH_SIZE=64
# Embedding 最大并发数
EMBEDDING_MAX_WORKERS=4

# ============ 检索参数 ============
# 相似度阈值 (0~1)，低于此值的检索结果将被视为"无相关内容"
SIMILARITY_THRESHOLD=0.3
# 检索返回的 chunk 数量
RETRIEVAL_K=10

# ============ 文档分块 ============
# 每个 chunk 的字符数（含 overlap）
CHUNK_SIZE=800
# 相邻 chunk 重叠字符数
CHUNK_OVERLAP=150

# ============ Reranker 精排 ============
RERANK_MODEL=gte-rerank-v2
RERANK_TOP_N=5

# ============ 缓存控制 ============
# 回答缓存最多条目数
CACHE_MAXSIZE=100
# 缓存存活秒数（默认 30 分钟）
CACHE_TTL=1800
